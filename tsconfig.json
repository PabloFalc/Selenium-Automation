{
  "$schema": "https://www.schemastore.org/tsconfig",

  "compilerOptions": {
    "lib": ["es2024"],
    "module": "es2020",
    "target": "es2024",
    "moduleResolution": "bundler",

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["jest"],
    "outDir": "dist",
    "rootDir": "./",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
